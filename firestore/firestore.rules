rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Bir etkinliğin verisini güvenlik içinde okur (read kurallarını bypass eder).
    function eventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }
    // base64 alan boyutu ~750KB altında mı (Firestore 1MB döküman limiti için).
    function smallEnough(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field].size() < 1000000;
    }

    // --- Kullanıcılar ---
    match /users/{uid} {
      // Profil okuma: giriş yapmış kullanıcılar (davetli listesi seçmek için).
      // Hassas veri (fcmTokens) ARTIK burada DEĞİL → users/{uid}/private altında.
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && request.resource.data.username is string
        && request.resource.data.username.size() <= 60
        && smallEnough('photoBase64')
        // Token'lar private/ altında tutulur; ana dokümana yazılamaz.
        && !('fcmTokens' in request.resource.data);

      allow update: if isSelf(uid)
        && smallEnough('photoBase64')
        && !('fcmTokens' in request.resource.data);

      allow delete: if isSelf(uid);

      // Özel/hassas veriler (fcmTokens vb.): sadece sahibi.
      // Cron worker (Admin SDK) kuralları bypass eder, erişebilir.
      match /private/{doc} {
        allow read, write: if isSelf(uid);
      }

      // Kaçırılan etkinlik kayıtları: sahibi okur/siler, sadece cron (Admin SDK) yazar.
      match /missed/{eventId} {
        allow read, delete: if isSelf(uid);
        allow create, update: if false;
      }
    }

    // --- Etkinlikler ---
    match /events/{eventId} {
      // Okuma: host ya da davetli olan kullanıcı
      allow read: if isSignedIn() && (
        resource.data.hostUid == request.auth.uid ||
        request.auth.uid in resource.data.inviteeUids
      );

      // Oluşturma: host kendisi olmalı + alan doğrulaması
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 120
        && request.resource.data.startAt is timestamp
        && request.resource.data.endAt is timestamp
        && request.resource.data.inviteeUids is list
        && request.resource.data.inviteeUids.size() <= 200
        && smallEnough('imageBase64')
        && smallEnough('noShowMessage');

      // Güncelleme: sadece host; hostUid değiştirilemez.
      allow update: if isSignedIn()
        && resource.data.hostUid == request.auth.uid
        && request.resource.data.hostUid == resource.data.hostUid
        && smallEnough('imageBase64');

      // Silme: sadece host
      allow delete: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;

      // --- RSVP yanıtları ---
      match /rsvps/{uid} {
        // Okuma: host ya da kendi yanıtı (rastgele enumerasyonu engeller).
        allow read: if isSelf(uid)
          || eventData(eventId).hostUid == request.auth.uid;

        // Oluşturma: host (başlangıç pending) ya da davetli kendi kaydı.
        allow create: if eventData(eventId).hostUid == request.auth.uid
          || (isSelf(uid) && request.auth.uid in eventData(eventId).inviteeUids);

        // Güncelleme: kendi yanıtı ya da host.
        allow update: if isSelf(uid)
          || eventData(eventId).hostUid == request.auth.uid;

        // Silme: kendi kaydı ya da host (etkinlik temizliği). Rastgele silmeyi engeller.
        allow delete: if isSelf(uid)
          || eventData(eventId).hostUid == request.auth.uid;
      }
    }

    // --- Bildirim kuyruğu ---
    // İstemci davet görevini buraya yazar; cron worker (Admin SDK, kuralları
    // bypass eder) okur, FCM gönderir ve siler. İstemci sadece create yapabilir.
    // KÖTÜYE KULLANIM KORUMASI: yalnızca etkinliğin host'u, o etkinliğin GERÇEK
    // davetlilerine 'invite' görevi yazabilir (rastgele push spam'i engellenir).
    match /notifications/{id} {
      allow create: if isSignedIn()
        && request.resource.data.kind == 'invite'
        && request.resource.data.eventId is string
        && eventData(request.resource.data.eventId).hostUid == request.auth.uid
        && request.resource.data.targetUids is list
        && request.resource.data.targetUids.size() <= 200
        && eventData(request.resource.data.eventId)
             .inviteeUids.hasAll(request.resource.data.targetUids)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 140
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 500;
      allow read, update, delete: if false;
    }
  }
}
